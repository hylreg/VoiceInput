export VOICEINPUT_ASR_MODEL_DIR='./models/Qwen/Qwen3-ASR-0.6B'
export VOICEINPUT_ASR_DEVICE='auto'
export VOICEINPUT_ASR_LANGUAGE='中文'
export VOICEINPUT_ASR_ITN='true'
export VOICEINPUT_ASR_HOTWORDS=''
